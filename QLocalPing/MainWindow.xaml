<Window x:Class="QLocalPing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QLocalPing"
        mc:Ignorable="d"
        xmlns:views="clr-namespace:QLocalPing.Views"
        Title="Ping" Height="450" Width="800" AllowsTransparency="True" WindowStyle="None" ResizeMode="CanResizeWithGrip">
    <Window.Template>
        <ControlTemplate TargetType="Window">
            <Grid>
                <Border Background="{TemplateBinding Background}" CornerRadius="10" Margin="5">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="0" Color="Black" Opacity="0.1"/>
                    </Border.Effect>
                </Border>
                <Border Background="{TemplateBinding Background}" CornerRadius="10" Margin="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border>
                            <Grid>
                                <Border Name="BD_DragMove" Background="Transparent"  PreviewMouseMove="BD_DragMove_PreviewMouseMove" PreviewMouseLeftButtonDown="BD_DragMove_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="BD_DragMove_PreviewMouseLeftButtonUp">

                                </Border>
                                <ContentControl HorizontalAlignment="Left" VerticalAlignment="Center" Content="{TemplateBinding Title}" Foreground="DimGray" Margin="15,5"/>
                                <WrapPanel HorizontalAlignment="Right" Margin="10,5">
                                    <Button Content="×" Foreground="Red" FontSize="20" Cursor="Hand" ToolTip="关闭" Name="BT_Close" Click="BT_Close_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Padding="5,0" Background="#3FFF0000" CornerRadius="5">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </WrapPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1">
                            <Grid>
                                <ContentPresenter/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

            </Grid>
        </ControlTemplate>
    </Window.Template>
    <Grid>
        <views:OnlineIpListPage/>
        <ResizeGrip HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5"/>
    </Grid>
</Window>
